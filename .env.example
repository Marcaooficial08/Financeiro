# Banco de dados (obrigatório em todos os ambientes).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth (obrigatório em todos os ambientes — app falha no startup sem NEXTAUTH_SECRET).
NEXTAUTH_SECRET="change-me-use-a-strong-random-string"
NEXTAUTH_URL="http://localhost:3000"

# URLs públicas usadas em emails (links de reset de senha) e domínio público.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="localhost"

# Resend (obrigatório quando NODE_ENV=production — habilita envio real de emails de reset de senha).
# Em desenvolvimento o conteúdo é apenas logado no console.
RESEND_API_KEY=""
RESEND_FROM="noreply@example.com"
